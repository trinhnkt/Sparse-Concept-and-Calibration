# master .gitignore for P0 repository

# Ignore everything under data recursively (files and directories)
p0-sparse-calibration-kt/data/**

# Unignore all directories so Git can traverse them to find .gitkeep files
!p0-sparse-calibration-kt/data/**/

# Unignore .gitkeep files so they are tracked
!p0-sparse-calibration-kt/data/**/.gitkeep

# Ignore large predictions
p0-sparse-calibration-kt/results/predictions/

# Python environment & cache
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
**/.pytest_cache/
**/.ipynb_checkpoints/

# Virtual Environments
**/.venv/
**/env/
**/venv/
**/ENV/

# System / IDE settings
**/.vscode/
**/.idea/
**/.DS_Store
**/Thumbs.db

# Saved weights / Models
**/*.pt
**/*.pth
**/*.pkl
**/*.bin

# Log files
**/logs/
**/*.log
**/*.csv.log
